rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Pet images — logged-in users upload; public read
    match /pets/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024   // max 5 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Surrender images — same rules as pets
    match /surrenders/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Lost & Found images
    match /lost_found/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Resource / article cover images — admin only write
    match /resources/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
