rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the requester an admin? ───────────────────
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Helper: requester is logged in ───────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    // ── users ─────────────────────────────────────────────────
    // Users can read/write their own doc; admins can read all
    match /users/{userId} {
      allow read:  if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isLoggedIn() && request.auth.uid == userId;
      allow update: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── pets ──────────────────────────────────────────────────
    // Anyone can read; logged-in users can create (surrender);
    // admin can update/delete
    match /pets/{petId} {
      allow read:   if true;
      allow create: if isLoggedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── pet_health_records ────────────────────────────────────
    // Anyone can read; only admins can write
    match /pet_health_records/{recordId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── adoption_requests ─────────────────────────────────────
    // Adopter can create and read their own; admin reads/updates all
    match /adoption_requests/{reqId} {
      allow read:   if isLoggedIn() &&
                       (resource.data.adopterId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn();
      allow update: if isAdmin() ||
                       (isLoggedIn() && resource.data.adopterId == request.auth.uid
                        && request.resource.data.status == 'pending');
      allow delete: if isLoggedIn() && resource.data.adopterId == request.auth.uid;
    }

    // ── lost_found ────────────────────────────────────────────
    // Anyone can read; logged-in users can post; owner or admin can delete
    match /lost_found/{postId} {
      allow read:   if true;
      allow create: if isLoggedIn();
      allow delete: if isLoggedIn() &&
                       (resource.data.reportedBy == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    // ── resources (articles) ──────────────────────────────────
    // Anyone can read; only admin can write
    match /resources/{resourceId} {
      allow read:  if true;
      allow write: if isAdmin();
    }
  }
}
