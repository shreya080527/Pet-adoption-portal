rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isLoggedIn() &&
        (request.auth.uid == userId || isAdmin());

      allow create: if isLoggedIn() &&
        request.auth.uid == userId;

      allow update: if isLoggedIn() &&
        (request.auth.uid == userId || isAdmin());

      allow delete: if isAdmin();
    }

    match /pets/{petId} {

      allow read: if true;

      allow create: if isLoggedIn();

      allow create: if
        request.resource.data.origin == 'found_stray'
        && request.resource.data.status == 'available'
        && request.resource.data.species is string
        && request.resource.data.foundLocation is string
        && request.resource.data.foundLocation.size() > 0
        && request.resource.data.photoURL is string
        && request.resource.data.keys().hasOnly([
          'name',
          'species',
          'breed',
          'ageGroup',
          'age',
          'gender',
          'size',
          'color',
          'description',
          'origin',
          'status',
          'foundLocation',
          'foundDate',
          'reporterName',
          'reporterContact',
          'photoURL',
          'imageURL',
          'addedAt'
        ]);

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /pet_health_records/{recordId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adoption_requests/{reqId} {
      allow read: if isLoggedIn() &&
        (resource.data.adopterId == request.auth.uid || isAdmin());

      allow create: if isLoggedIn();

      allow update: if isAdmin() ||
        (isLoggedIn() &&
         resource.data.adopterId == request.auth.uid &&
         request.resource.data.status == 'pending');

      allow delete: if isLoggedIn() &&
        resource.data.adopterId == request.auth.uid;
    }

    match /lost_found/{postId} {
      allow read: if true;

      allow create: if isLoggedIn();

      allow delete: if isLoggedIn() &&
        (resource.data.reportedBy == request.auth.uid || isAdmin());

      allow update: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}